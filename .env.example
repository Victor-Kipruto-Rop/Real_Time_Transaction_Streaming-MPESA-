# Environment variables for Project 01: Real-Time M-Pesa Transaction Streaming
#
# Copy to `.env` and fill in real values. Do not commit `.env`.

# Runtime
LOG_LEVEL=INFO

# PostgreSQL (local docker-compose defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mpesa_analytics
POSTGRES_USER=data_engineer
POSTGRES_PASSWORD=change_me

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=mpesa-transactions
KAFKA_TOPIC_ALERTS=mpesa-fraud-alerts
KAFKA_GROUP_ID=mpesa_streaming_group

# ============================================================================
# SAFARICOM DARAJA API (M-Pesa Integration)
# Get credentials from: https://developer.safaricom.co.ke
# DO NOT commit real credentials to git!
# ============================================================================
DARAJA_ENVIRONMENT=sandbox
# Options: sandbox (testing) | production (live)

DARAJA_CONSUMER_KEY=your_consumer_key_from_daraja_portal
DARAJA_CONSUMER_SECRET=your_consumer_secret_from_daraja_portal
DARAJA_BUSINESS_SHORTCODE=your_business_shortcode
DARAJA_SHORTCODE=your_business_shortcode
DARAJA_C2B_SHORTCODE=your_business_shortcode
DARAJA_PASSKEY=your_lipa_na_mpesa_passkey
DARAJA_RESPONSE_TYPE=Completed
DARAJA_TIMEOUT=30

# ============================================================================
# M-PESA TILL DETAILS
# Get from your M-Pesa dashboard or Daraja portal
# ============================================================================
MPESA_BUSINESS_SHORTCODE=your_business_shortcode
MPESA_TILL_NUMBER=your_till_number
MPESA_TILL_MSISDN=your_till_msisdn
MPESA_PASSKEY=your_lipa_na_mpesa_passkey

# ============================================================================
# WEBHOOKS & CALLBACKS
# URLs where M-Pesa will send transaction confirmations
# ============================================================================
DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost:5000
CALLBACK_URL=http://localhost:5000/webhook/stk/callback
DARAJA_STK_CALLBACK_URL=http://localhost:5000/webhook/stk/callback
DARAJA_VALIDATION_URL=http://localhost:5000/webhook/c2b/validation
DARAJA_CONFIRMATION_URL=http://localhost:5000/webhook/c2b/confirmation
DARAJA_B2C_RESULT_URL=http://localhost:5000/webhook/b2c/result
DARAJA_B2C_TIMEOUT_URL=http://localhost:5000/webhook/b2c/result
C2B_VALIDATION_URL=http://localhost:5000/webhook/c2b/validation
C2B_CONFIRMATION_URL=http://localhost:5000/webhook/c2b/confirmation
CALLBACK_TIMEOUT=30
CALLBACK_RETRY_ATTEMPTS=3

# AWS RDS with IAM Authentication
# Uncomment and configure these to use AWS RDS instead of local PostgreSQL
# RDS_DB_HOST=your-db-instance.region.rds.amazonaws.com
# RDS_DB_PORT=5432
# RDS_DB_NAME=postgres
# RDS_DB_USER=postgres
# AWS_REGION=us-west-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
