# M-Pesa Analytics Platform - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# DARAJA API CONFIGURATION (Safaricom M-Pesa)
# ============================================================================
# Get credentials from: https://developer.safaricom.co.ke/
DARAJA_ENVIRONMENT=sandbox
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_BUSINESS_SHORTCODE=174379
DARAJA_C2B_SHORTCODE=174379
DARAJA_PASSKEY=your_passkey_here
DARAJA_RESPONSE_TYPE=Completed

# Webhook URLs (must be publicly accessible HTTPS URLs)
DOMAIN=your-domain.com
PUBLIC_BASE_URL=https://your-domain.com
C2B_VALIDATION_URL=https://your-domain.com/webhook/c2b/validation
C2B_CONFIRMATION_URL=https://your-domain.com/webhook/c2b/confirmation
DARAJA_VALIDATION_URL=https://your-domain.com/webhook/c2b/validation
DARAJA_CONFIRMATION_URL=https://your-domain.com/webhook/c2b/confirmation
DARAJA_STK_CALLBACK_URL=https://your-domain.com/webhook/stk/callback
DARAJA_B2C_RESULT_URL=https://your-domain.com/webhook/b2c/result
DARAJA_B2C_TIMEOUT_URL=https://your-domain.com/webhook/b2c/timeout
CALLBACK_URL=https://your-domain.com/webhook/callback

# M-Pesa Business Configuration
MPESA_BUSINESS_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_here

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_DB=mpesa_analytics
POSTGRES_USER=data_engineer
POSTGRES_PASSWORD=change_me_to_secure_password

# ============================================================================
# AWS RDS CONFIGURATION (Optional - for production)
# ============================================================================
# AWS_REGION=us-east-1
# RDS_HOST=your-rds-instance.region.rds.amazonaws.com
# RDS_PORT=5432
# RDS_DB_NAME=mpesa_analytics
# RDS_USERNAME=rds_iam_user
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================================================
# KAFKA CONFIGURATION
# ============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_HOST_PORT=9092
KAFKA_TOPIC_TRANSACTIONS=mpesa-transactions
KAFKA_GROUP_ID=mpesa_streaming_group

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HOST_PORT=6379

# ============================================================================
# GRAFANA CONFIGURATION
# ============================================================================
GRAFANA_VERSION=latest
GRAFANA_HOST_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVE_FROM_SUB_PATH=false

# ============================================================================
# WEBHOOK RECEIVER CONFIGURATION
# ============================================================================
WEBHOOK_HOST_PORT=5000
LOG_LEVEL=INFO
RATE_LIMIT_PER_MIN=120

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# UI Authentication Token (generate a secure random string)
UI_TOKEN=your_secure_token_here

# ============================================================================
# JUPYTER NOTEBOOK CONFIGURATION (Optional)
# ============================================================================
JUPYTER_HOST_PORT=8888

# ============================================================================
# DBT CONFIGURATION
# ============================================================================
DBT_LOG_PATH=/tmp/mpesa-dbt-logs
DBT_TARGET_PATH=/tmp/mpesa-dbt-target

# ============================================================================
# GCP CONFIGURATION (Optional - for production)
# ============================================================================
# GCP_PROJECT_ID=your-gcp-project
# GCP_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================================================
# MONITORING & ALERTING (Optional)
# ============================================================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# PAGERDUTY_API_KEY=your_pagerduty_api_key
# ALERT_EMAIL=alerts@your-domain.com

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================
# ENABLE_FRAUD_DETECTION=true
# ENABLE_REAL_TIME_ANALYTICS=true
# ENABLE_ML_PREDICTIONS=false

# ============================================================================
# DEVELOPMENT/TESTING (Optional)
# ============================================================================
# TESTING=false
# DEBUG=false
# MOCK_DARAJA_API=false
